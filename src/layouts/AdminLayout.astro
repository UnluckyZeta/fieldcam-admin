---
import Sidebar from "../components/Sidebar.astro";

const {
  title = "FieldCam Admin",
} = Astro.props;

const isLoginPage =
  Astro.url.pathname ===
  "/login";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    {
      !isLoginPage && (
        <script type="module">
          import { supabase }
            from "../lib/supabase";

          const {
            data: {
              session,
            },
          } =
            await supabase.auth.getSession();

          if (!session) {
            location.replace(
              "/login",
            );
          } else {
            document.body.style.visibility =
              "visible";
          }
        </script>
      )
    }
  </head>

  <body
    style={
      !isLoginPage
        ? "visibility:hidden"
        : ""
    }
  >
    {
      isLoginPage ? (
        <main class="login-main">
          <slot />
        </main>
      ) : (
        <div class="app">
          <Sidebar />

          <main>
            <slot />
          </main>
        </div>
      )
    }
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family:
      Arial,
      sans-serif;
    background: #f5f5f5;
  }

  .app {
    display: flex;
    min-height: 100vh;
  }

  main {
    flex: 1;
    padding: 24px;
  }

  .login-main {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>