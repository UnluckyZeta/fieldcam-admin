---
import EngineersTable from "../components/EngineersTable.astro";
import AdminLayout from "../layouts/AdminLayout.astro";

import { getEngineers } from "../lib/api";
const adminId =
  Astro.cookies
    .get("admin_id")
    ?.value ?? "";

const data =
  await getEngineers(
    "",
    "",
    adminId,
  );

const engineers =
  data.engineers ?? [];
---

<AdminLayout title="Engineers">
  <div class="card">
    <h2>Create Engineer</h2>

    <form
      id="create-engineer-form"
      class="create-form"
    >
      <input
        id="full_name"
        placeholder="Full Name"
      />

      <input
        id="email"
        placeholder="Email"
      />
<input
  id="phone"
  placeholder="Phone Number"
/>
      <button type="submit">
        Create Engineer
      </button>
    </form>
  </div>

  <div class="toolbar">
    <input
      id="search"
      class="search-input"
      placeholder="Search engineer..."
    />
  </div>

  <EngineersTable
    engineers={engineers}
  />
</AdminLayout>

<style>
  .card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    box-shadow:
      0 2px 8px
      rgba(
        0,
        0,
        0,
        0.05
      );
  }

  .card h2 {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .create-form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .create-form input,
  .search-input {
    height: 40px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    background: white;
  }

  .create-form input {
    min-width: 240px;
  }

  .create-form button {
    height: 40px;
    padding: 0 16px;
    border: none;
    border-radius: 6px;
    background: #16a34a;
    color: white;
    font-weight: 500;
    cursor: pointer;
  }

  .create-form button:hover {
    background: #15803d;
  }

  .toolbar {
    background: white;
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    box-shadow:
      0 2px 8px
      rgba(
        0,
        0,
        0,
        0.05
      );
  }

  .search-input {
    width: 100%;
    max-width: 400px;
  }
</style>

<script type="module">
  import "../scripts/engineers";
  import {
    requireAdmin,
  } from "../lib/auth";

  requireAdmin();

</script>