---
import EngineersTable from "../components/EngineersTable.astro";
import AdminLayout from "../layouts/AdminLayout.astro";

import { getEngineers } from "../lib/api";
const adminId =
  Astro.cookies
    .get("admin_id")
    ?.value ?? "";

const engineers = [];
---

<AdminLayout title="Engineers">
  <div class="card">
    <h2>Create Engineer</h2>

    <form
      id="create-engineer-form"
      class="create-form"
    >
      <input
        id="full_name"
        placeholder="Full Name"
      />

      <input
        id="email"
        placeholder="Email"
      />
<input
  id="phone"
  placeholder="Phone Number"
/>
<select id="region">
  <option value="">Select Region</option>
  <option value="cairo">Cairo</option>
  <option value="giza">Giza</option>
  <option value="alexandria">Alexandria</option>
  <option value="dakahlia">Dakahlia</option>
  <option value="sharqia">Sharqia</option>
  <option value="gharbia">Gharbia</option>
  <option value="beheira">Beheira</option>
  <option value="port said">Port Said</option>
  <option value="ismailia">Ismailia</option>
  <option value="suez">Suez</option>
  <option value="kafr el sheikh">Kafr El Sheikh</option>
  <option value="damietta">Damietta</option>
  <option value="minya">Minya</option>
  <option value="assiut">Assiut</option>
  <option value="sohag">Sohag</option>
  <option value="qena">Qena</option>
  <option value="luxor">Luxor</option>
  <option value="aswan">Aswan</option>
</select>
      <button type="submit">
        Create Engineer
      </button>
    </form>
    <div
  id="create-engineer-result"
  class="result-card"
  style="display:none;"
>
  <h3>
    ✅ Engineer Created
  </h3>

  <div>
    <strong>Email:</strong>
    <span id="engineer-email"></span>
  </div>

  <div>
    <strong>Password:</strong>
    <span id="engineer-password"></span>
  </div>

  <div>
    <strong>Engineer Code:</strong>
    <span id="engineer-code"></span>
  </div>

  <button
    id="copy-engineer-creds"
    class="btn-copy"
  >
    Copy Credentials
  </button>
</div>
  </div>

  <div class="toolbar">
    <div class="toolbar-controls">
      <input
        id="search"
        class="search-input"
        placeholder="Search by name, engineer code, or email..."
      />
      <select id="region-filter" class="filter-select">
        <option value="">All Regions</option>
        <option value="cairo">Cairo</option>
        <option value="giza">Giza</option>
        <option value="alexandria">Alexandria</option>
        <option value="dakahlia">Dakahlia</option>
        <option value="sharqia">Sharqia</option>
        <option value="gharbia">Gharbia</option>
        <option value="beheira">Beheira</option>
        <option value="port said">Port Said</option>
        <option value="ismailia">Ismailia</option>
        <option value="suez">Suez</option>
        <option value="kafr el sheikh">Kafr El Sheikh</option>
        <option value="damietta">Damietta</option>
        <option value="minya">Minya</option>
        <option value="assiut">Assiut</option>
        <option value="sohag">Sohag</option>
        <option value="qena">Qena</option>
        <option value="luxor">Luxor</option>
        <option value="aswan">Aswan</option>
      </select>
    </div>
  </div>

  <EngineersTable
    engineers={engineers}
  />
</AdminLayout>

<style>
  .card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    box-shadow:
      0 2px 8px
      rgba(
        0,
        0,
        0,
        0.05
      );
  }

  .card h2 {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .create-form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .create-form input,
  .create-form select,
  .search-input,
  .filter-select {
    height: 40px;
    padding: 0 12px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 14px;
    background: white;
  }

  .create-form input {
    min-width: 240px;
  }

  .create-form button {
    height: 40px;
    padding: 0 16px;
    border: none;
    border-radius: 6px;
    background: #16a34a;
    color: white;
    font-weight: 500;
    cursor: pointer;
  }

  .result-card {
  margin-top: 20px;
  padding: 16px;
  background: #ecfdf5;
  border: 1px solid #86efac;
  border-radius: 8px;
}

.result-card h3 {
  margin-top: 0;
  margin-bottom: 12px;
}

.btn-copy {
  margin-top: 12px;
  border: none;
  border-radius: 6px;
  padding: 10px 16px;
  cursor: pointer;
  background: #16a34a;
  color: white;
}
  .create-form button:hover {
    background: #15803d;
  }

  .toolbar {
    background: white;
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    box-shadow:
      0 2px 8px
      rgba(
        0,
        0,
        0,
        0.05
      );
  }

  .toolbar-controls {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-input {
    flex: 1;
    min-width: 260px;
    max-width: 400px;
  }

  .filter-select {
    min-width: 180px;
    cursor: pointer;
  }
</style>

<script type="module">
  import "../scripts/engineers";
  import {
    requireAdmin,
  } from "../lib/auth";

  requireAdmin();

</script>