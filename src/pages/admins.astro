---
import AdminLayout
  from "../layouts/AdminLayout.astro";

import {
  getAdmins,
} from "../lib/api";

const adminId =
  Astro.cookies
    .get("admin_id")
    ?.value ?? "";

const data =
  await getAdmins(
    adminId,
  );

if (!data.success) {
  return Astro.redirect("/");
}

const admins =
  data.admins ?? [];
    
---

<AdminLayout title="Admins">

<h1>
  Admin Management
</h1>

<div class="card">
  <h2>
    Create Admin
  </h2>

  <form
    id="create-admin-form"
  >
    <input
      id="full_name"
      placeholder="Full Name"
    />

    <input
      id="email"
      placeholder="Email"
    />

    <select
      id="role"
    >
      <option value="regional_admin">
        Regional Admin
      </option>

      <option value="super_admin">
        Super Admin
      </option>
    </select>

    <input
      id="region"
      placeholder="Region"
    />

    <button
      type="submit"
    >
      Create
    </button>
  
  </form>
<div
  id="create-admin-result"
  class="result-card"
  style="display:none;"
>
  <h3>
    ✅ Admin Created
  </h3>

  <div>
    <strong>Email:</strong>
    <span id="created-email"></span>
  </div>

  <div>
    <strong>Password:</strong>
    <span id="created-password"></span>
  </div>

  <button
    id="copy-admin-creds"
    class="btn-copy"
  >
    Copy Credentials
  </button>
</div>
</div>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Region</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    
    {admins.map(
      (
        admin: any,
      ) => (
        <tr>
          <td>
            {
              admin.full_name
            }
          </td>

          <td>
            {
              admin.email
            }
          </td>

          <td>
            {
              admin.role
            }
          </td>

          <td>
            {
              admin.region ??
              "-"
            }
          </td>
          <td class="actions">
  <button
  class="btn btn-edit"
  onclick={`editAdminUi(
    '${admin.id}',
    '${admin.full_name}',
    '${admin.email}',
    '${admin.role}',
    '${admin.region ?? ""}'
  )`}
>
  Edit
</button>

<button
  class="btn btn-password"
  onclick={`resetPasswordUi(
    '${admin.id}'
  )`}
>
  Reset Password
</button>
<button
  class="btn btn-delete"
  onclick={`deleteAdminUi(
    '${admin.id}'
  )`}
>
  Delete
</button>
</td>
        </tr>
      ),
    )}
  </tbody>
</table>

</AdminLayout>
<script type="module">
  import "../scripts/admin";
</script>
<style>
    .card {
  background: white;
  padding: 20px;
  border-radius: 8px;
  margin-bottom: 24px;
}

#create-admin-form {
  display: grid;
  grid-template-columns:
    repeat(
      auto-fit,
      minmax(220px, 1fr)
    );
  gap: 12px;
}

#create-admin-form input,
#create-admin-form select {
  height: 42px;
  padding: 0 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
}

#create-admin-form button {
  height: 42px;
  border: none;
  border-radius: 6px;
  background: #2563eb;
  color: white;
  cursor: pointer;
}

table {
  width: 100%;
  background: white;
  border-collapse: collapse;
  border-radius: 8px;
  overflow: hidden;
}

th,
td {
  padding: 12px;
  border: 1px solid #e5e7eb;
  text-align: left;
}

th {
  background: #f8fafc;
}

tr:hover {
  background: #f9fafb;
}
.actions {
  display: flex;
  gap: 8px;
}

.btn {
  border: none;
  border-radius: 6px;
  padding: 8px 12px;
  cursor: pointer;
  color: white;
}

.btn-edit {
  background: #f59e0b;
}

.btn-password {
  background: #7c3aed;
}
.btn-delete {
  background: #ed3a3a;
}
.result-card {
  margin-top: 20px;
  padding: 16px;
  background: #ecfdf5;
  border: 1px solid #86efac;
  border-radius: 8px;
}

.result-card h3 {
  margin-top: 0;
}

.result-row {
  margin-bottom: 8px;
}

.btn-copy {
  border: none;
  padding: 10px 16px;
  border-radius: 6px;
  cursor: pointer;
  background: #16a34a;
  color: white;
}
.result-card {
  margin-top: 20px;
  padding: 16px;
  background: #ecfdf5;
  border: 1px solid #86efac;
  border-radius: 8px;
}

.result-card h3 {
  margin-top: 0;
  margin-bottom: 12px;
}

.btn-copy {
  margin-top: 12px;
  border: none;
  border-radius: 6px;
  padding: 10px 16px;
  cursor: pointer;
  background: #16a34a;
  color: white;
}
</style>