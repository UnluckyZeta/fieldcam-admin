---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getEngineer } from "../../lib/api";
function formatEgyptDate(
  date: string,
) {
  return new Date(date)
    .toLocaleString(
      "en-US",
      {
        timeZone:
          "Africa/Cairo",
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      },
    )
    .replace(",", " •");
}
const { id } = Astro.params;

const from =
  Astro.url.searchParams.get(
    "from",
  ) ?? "";

const to =
  Astro.url.searchParams.get(
    "to",
  ) ?? "";

const data =
  await getEngineer(
    id!,
    from,
    to,
  );

const engineer =
  data.engineer;
  
---

<AdminLayout title="Engineer Details">
  <div class="page-container">
  <h1>
    {engineer.full_name}
  </h1>

<div class="stats">
  <div class="stat-card">
    <h3>Email</h3>
    <p>{engineer.email}</p>
  </div>

  <div class="stat-card">
    <h3>Engineer Code</h3>
    <p>{engineer.engineer_code}</p>
  </div>
<div class="stat-card">
  <h3>
    Assigned Region
  </h3>

 <p>
  {engineer.region ||
    data.auto_region ||
    "Unknown"}
</p>
</div>

<div class="stat-card">
  <h3>
    Assigned Subregion
  </h3>

<p>
  {engineer.subregion ||
    data.auto_subregion ||
    "Unknown"}
</p>
</div>

<div class="stat-card">
  <h3>
    Current Region
  </h3>

  <p>
    {data.auto_region ??
      "Unknown"}
  </p>
</div>

<div class="stat-card">
  <h3>
    Current Subregion
  </h3>

  <p>
    {data.auto_subregion ??
      "Unknown"}
  </p>
</div>
  <div class="stat-card">
    <h3>Device ID</h3>
    <p>
      {engineer.device_id ??
        "Not Registered"}
    </p>
  </div>

  <div class="stat-card">
    <h3>Total Photos</h3>
    <p>{data.total_photos}</p>
  </div>

  <div class="stat-card">
    <h3>Last Photo</h3>
    <p>
     {data.last_photo
  ? formatEgyptDate(
      data.last_photo.taken_at,
    )
  : "Never"}
    </p>
  </div>
  <div class="stat-card">
  <h3>Last Location</h3>

  <p>
    {
      data.last_photo?.address ??
      "Unknown"
    }
  </p>
</div>
<div class="stat-card">
  <h3>Phone</h3>

  <p>
    {engineer.phone ??
      "Not Set"}
  </p>
</div>

<div class="stat-card">
  <h3>
    Current Device
  </h3>

  <p>
    {engineer.device_id ??
      "Unknown"}
  </p>
</div>

<div class="stat-card">
  <h3>
    Devices Used
  </h3>

  <p>
    {data.device_count}
  </p>
</div>


<div class="stat-card region-card">
  <h3>Region Settings</h3>

  <div class="region-actions">
    <button
      class="btn-edit-region"
      onclick={`editRegionUi(
        '${engineer.id}',
        '${engineer.region ?? ""}',
        '${engineer.subregion ?? ""}'
      )`}
    >
      Edit Region
    </button>
  </div>
</div>
</div>

<form method="GET" class="filters">
  <input
      type="date"
      onfocus="this.showPicker()"
    name="from"
    value={
      Astro.url.searchParams.get(
        "from",
      ) ?? ""
    }
  />

  <input
      type="date"
      onfocus="this.showPicker()"
    name="to"
    value={
      Astro.url.searchParams.get(
        "to",
      ) ?? ""
    }
  />

  <button type="submit">
    Filter
  </button>
  <a
  href={`/engineers/${id}`}
  class="btn-reset"
>
  Reset
</a>
</form>

<h2>Recent Photos</h2>

<table class="photos-table">
  <thead>
    <tr>
      <th>Tag</th>
      <th>Date</th>
      <th>Address</th>
      <th>Risk</th>
      <th>Verify</th>
    </tr>
  </thead>

  <tbody>
    {data.recent_photos.map(
      (photo: any) => (
        <tr>
          <td>
            {photo.photo_tag}
          </td>

          <td>
          {formatEgyptDate(
  photo.taken_at,
)}
          </td>

          <td>
            {photo.address}
          </td>

<td>
  <span
    class={
      photo.gps_risk === "high"
        ? "danger"
        : "success"
    }
  >
    {
      photo.gps_risk === "high"
        ? "⚠ High"
        : "✅ Normal"
    }
  </span>
</td>

<td>
  <a
    class="btn"
    href={`/verify?tag=${photo.photo_tag}`}
  >
    Verify
  </a>
</td>
        </tr>
      ),
    )}
  </tbody>
</table>
<h2>
  Device History
</h2>

<table class="photos-table">
  <thead>
    <tr>
      <th>
        Device ID
      </th>

      <th>
        First Seen
      </th>

      <th>
        Last Seen
      </th>

      <th>
        Photos
      </th>
    </tr>
  </thead>

  <tbody>
    {data.device_history.map(
      (device: any) => (
        <tr>
          <td>
            {
              device.device_id
            }
          </td>

          <td>
            {new Date(
              device.first_seen,
            ).toLocaleDateString()}
          </td>

          <td>
            {new Date(
              device.last_seen,
            ).toLocaleDateString()}
          </td>

          <td>
            {device.photos}
          </td>
        </tr>
      ),
    )}
  </tbody>
</table>
</div>
</AdminLayout>

<style>
.region-card {
  display: flex;
  flex-direction: column;
}

.region-card h3 {
  margin-bottom: 16px;
}

.region-actions {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.stats {
  display: grid;
  grid-template-columns:
    repeat(
      auto-fit,
      minmax(220px, 1fr)
    );
  gap: 16px;
  margin-bottom: 24px;
}

.stat-card {
  background: white;
  border-radius: 8px;
  padding: 16px;
  box-shadow:
    0 2px 8px
    rgba(
      0,
      0,
      0,
      0.05
    );
}

.stat-card h3 {
  margin: 0;
  font-size: 14px;
  color: #6b7280;
}

.stat-card p {
  margin-top: 8px;
  font-size: 18px;
  font-weight: 600;
  word-break: break-word;
}

.region-actions {
  margin-bottom: 24px;
}

.btn-edit-region {
  height: 40px;
  padding: 0 16px;
  border: none;
  border-radius: 6px;
  background: #2563eb;
  color: white;
  cursor: pointer;
  font-weight: 500;
}

.btn-edit-region:hover {
  background: #1d4ed8;
}

.filters {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.filters input[type="date"] {
  height: 40px;
  padding: 0 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  background: white;
  cursor: pointer;
}

.filters button,
.btn-reset {
  height: 40px;
  padding: 0 16px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
}

.filters button {
  background: #2563eb;
  color: white;
}

.filters button:hover {
  background: #1d4ed8;
}

.btn-reset {
  background: #6b7280;
  color: white;
}

.btn-reset:hover {
  background: #4b5563;
}

.photos-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 8px;
  overflow: hidden;
}

.photos-table th,
.photos-table td {
  padding: 12px;
  border: 1px solid #e5e7eb;
  text-align: left;
}

.photos-table th {
  background: #f8fafc;
  font-weight: 600;
}

.photos-table tr:hover {
  background: #f9fafb;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 12px;
  border-radius: 6px;
  background: #2563eb;
  color: white;
  text-decoration: none;
}

.btn:hover {
  background: #1d4ed8;
}

.danger {
  color: #dc2626;
  font-weight: 600;
}

.success {
  color: #16a34a;
  font-weight: 600;
}
</style>
<script type="module">
  import "../../scripts/engineers";
</script>