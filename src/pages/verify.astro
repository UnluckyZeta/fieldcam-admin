---
import AdminLayout from "../layouts/AdminLayout.astro";
import { verifyPhoto } from "../lib/api";

const tag =
  Astro.url.searchParams.get("tag");

let result = null;

if (tag) {
  result = await verifyPhoto(tag);
}
console.log(result);

---

<AdminLayout title="Verify Photo">
  <h1>Verify Photo</h1>

  <form method="GET">
    <input
      name="tag"
      placeholder="FC-BDC243FC"
      value={tag ?? ""}
    />

    <button type="submit">
      Verify
    </button>
  </form>

  {
    result?.found && (
      <div class="card">
   

        <p>
          Engineer:
          {result.photo.full_name}
        </p>

        <p>
          Engineer Code:
          {result.photo.engineer_code}
        </p>
 <p>
  Email:
  {result.photo.email ??
    "Not Available"}
</p>

<p>
  Phone:
  {result.photo.phone ??
    "Not Available"}
</p>

        <p>
          Photo Tag:
          {result.photo.photo_tag}
        </p>

        <p>
          Date:
{
  new Date(
    result.photo.taken_at,
  ).toLocaleString(
    "en-GB",
    {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    },
  )
}        </p>

        <p>
          Address:
          {result.photo.address}
        </p>

        <p>
          GPS:
          {result.photo.latitude},
          {result.photo.longitude}
        </p>
      </div>
    )
  }

  {
    tag &&
      !result?.found && (
        <div class="card error">
          ❌ Photo not found
        </div>
      )
  }
</AdminLayout>

<style>
  form {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }

  input {
    flex: 1;
    padding: 10px;
  }

  .card {
    background: white;
    padding: 20px;
    border-radius: 8px;
  }

  .error {
    color: red;
  }
</style>