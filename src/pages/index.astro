---
import AdminLayout from "../layouts/AdminLayout.astro";
import { getDashboard } from "../lib/api";


const today =
  new Date()
    .toISOString()
    .split("T")[0];

const from =
  Astro.url.searchParams.get(
    "from",
  ) ?? today;

const to =
  Astro.url.searchParams.get(
    "to",
  ) ?? today;

const adminId =
  Astro.cookies
    .get("admin_id")
    ?.value ?? "";
    

    const data =
  await getDashboard(
    from,
    to,adminId
  );
   
---

<AdminLayout title="Dashboard">
  <h1>Dashboard</h1>
<div class="toolbar">
  <form method="GET" class="filters">
    <input
      type="date"
      name="from"
      value={from}
      onfocus="this.showPicker()"
    />

    <input
      type="date"
      name="to"
      value={to}
      onfocus="this.showPicker()"
    />

    <button type="submit">
      Apply
    </button>

    <a
      href="/"
      class="btn-reset"
    >
      Reset
    </a>

    <button
      id="export-btn"
      type="button"
      class="btn-export"
    >
      Export CSV
    </button>
  </form>
</div>
  <div class="stats">
    <div class="stat-card">
      <h3>Total Engineers</h3>
      <p>
        {data.total_engineers}
      </p>
    </div>

    <div class="stat-card">
      <h3>Total Photos</h3>
      <p>
        {data.total_photos}
      </p>
    </div>

    <div class="stat-card">
      <h3>Photos Today</h3>
      <p>
        {data.photos_today}
      </p>
    </div>

    <div class="stat-card">
      <h3>GPS Risk</h3>

      <p
        class={
          data.gps_risk_engineers >
          0
            ? "danger"
            : "success"
        }
      >
        {
          data.gps_risk_engineers
        }
      </p>
    </div>
  </div>

  <div class="section">
    <h2>
      High Risk Engineers
    </h2>

    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Code</th>
          <th>Risk</th>
          <th>View</th>
        </tr>
      </thead>

      <tbody>
        {data.high_risk_engineers.map(
          (
            engineer: any,
          ) => (
            <tr>
              <td>
                {
                  engineer.full_name
                }
              </td>

              <td>
                {
                  engineer.engineer_code
                }
              </td>

              <td>
                ⚠ High
              </td>

              <td>
                <a
                  class="btn"
                  href={`/engineers/${engineer.id}`}
                >
                  View
                </a>
              </td>
            </tr>
          ),
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .stats {
    display: grid;
    grid-template-columns:
      repeat(
        auto-fit,
        minmax(
          220px,
          1fr
        )
      );
    gap: 16px;
    margin-bottom: 32px;
  }
.filters {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
}

.filters input {
  padding: 10px;
}

.filters button {
  padding: 10px 16px;
  cursor: pointer;
}
  .stat-card {
    background: white;
    border-radius: 8px;
    padding: 16px;
    box-shadow:
      0 2px 8px
      rgba(
        0,
        0,
        0,
        0.05
      );
  }

  .stat-card h3 {
    margin: 0;
    font-size: 14px;
    color: #666;
  }
.filters {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.filters input[type="date"] {
  padding: 10px 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  background: white;
  cursor: pointer;
  min-width: 160px;
}

.filters button,
.btn-reset {
  height: 40px;
  padding: 0 16px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
}

.filters button {
  background: #2563eb;
  color: white;
}

.btn-reset {
  background: #6b7280;
  color: white;
}

.filters button:hover {
  background: #1d4ed8;
}

.btn-reset:hover {
  background: #4b5563;
}
.reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
  background: #6b7280;
  color: white;
  text-decoration: none;
  border-radius: 6px;
}
  .stat-card p {
    margin-top: 8px;
    font-size: 28px;
    font-weight: 700;
  }

  .section {
    background: white;
    border-radius: 8px;
    padding: 20px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    padding: 12px;
    border: 1px solid #e5e7eb;
    text-align: left;
  }

  th {
    background: #f8fafc;
  }

  .btn {
    display: inline-block;
    padding: 6px 12px;
    background: #2563eb;
    color: white;
    text-decoration: none;
    border-radius: 6px;
  }

  .danger {
    color: #dc2626;
  }

  .success {
    color: #16a34a;
  }input[  type="date"
      onfocus="this.showPicker()"] {
  cursor: pointer;
}
</style>
<script type="module">
  import "../scripts/dashboard";
    import {
    requireAdmin,
  } from "../lib/auth";

  requireAdmin();

</script>