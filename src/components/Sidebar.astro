
---

const adminRole =
  Astro.cookies
    .get("admin_role")
    ?.value;
    console.log(adminRole)
  ---

  <nav class="sidebar">
  <a href="/">Dashboard</a>
  <a href="/engineers">Engineers</a>
  <a href="/workers">Workers</a>
  <a href="/drivers">Drivers</a>
  <a href="/daily-runs">Daily Runs</a>
  <a href="/verify">Verify</a>
{
  adminRole ===
    "super_admin" && (
    <a href="/admins">
      Admins
    </a>
  )
}
  <button
  onclick="logout()"
  class="logout-btn"
>
  Logout
</button>
</nav>

<style>
  .sidebar {
    width: 220px;
    min-height: 100vh;
    background: white;
    border-right: 1px solid #ddd;

    display: flex;
    flex-direction: column;
    gap: 12px;

    padding: 20px;
  }

  .sidebar a {
    text-decoration: none;
    color: black;
  }
  .logout-btn {
  width: 100%;
  margin-top: auto;
  padding: 10px;
  border: none;
  border-radius: 6px;
  background: #dc2626;
  color: white;
  cursor: pointer;
}

.logout-btn:hover {
  background: #b91c1c;
}
</style>
<script type="module">
  import "../../src/scripts/auth";
</script>